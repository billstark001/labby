{
  "name": "labby",
  "version": "0.0.1",
  "private": true,
  "description": "Academic seminar scheduling system",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @labby/core build",
    "build:server": "pnpm --filter @labby/server build",
    "build:server:web": "pnpm --filter @labby/web build:server",
    "build:web": "pnpm --filter @labby/web build:frontend",
    "dev": "pnpm --filter @labby/web dev:frontend",
    "dev:server": "pnpm --filter @labby/server dev",
    "dev:server:web": "pnpm --filter @labby/web dev:server",
    "preview": "pnpm --filter @labby/web preview",
    "deploy:cloudrun:incremental": "pnpm --filter @labby/server exec tsx ../../scripts/cloud-run-incremental-deploy.ts",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "typescript": "^6.0.2"
  }
}
