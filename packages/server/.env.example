# Labby server environment configuration
# Copy this file to .env and fill in the values.

# Server
PORT=4410
DB_PATH=./run/labby.db
WEB_DIST_DIR=../web/dist

# PASETO token signing secret (generate with: openssl rand -base64 32)
PASETO_SECRET=your-secret-here
# Or use separate keys:
# PASETO_ACCESS_KEY=k4.local.your-access-key-here
# PASETO_REFRESH_KEY=k4.local.your-refresh-key-here

# Token TTLs
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=30d

# Root user (credentials from environment only, NEVER stored in the database)
ROOT_USERNAME=root
ROOT_PASSWORD=change-me-immediately
ROOT_EMAIL=root@example.com

# SMTP (optional – leave SMTP_HOST blank to disable email notifications)
SMTP_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Labby <noreply@example.com>

# Gmail OAuth (optional alternative to raw SMTP credentials)
GMAIL_USER=
GMAIL_REFRESH_TOKEN=
GOOGLE_OAUTH_JSON_PATH=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_REFRESH_TOKEN_PATH=

# Public ICS endpoint for email tasks (optional)
ENABLE_PUBLIC_EMAIL_TASK_ICS=false
PUBLIC_BASE_URL=http://localhost:4410

# Comma-separated list of email addresses to notify
NOTIFY_RECIPIENTS=

# Backup subsystem (leave BACKUP_CRON blank to disable)
BACKUP_CRON=
BACKUP_TIMEZONE=UTC
BACKUP_FORMAT=sqlite
BACKUP_TARGET=email
BACKUP_FILENAME_PREFIX=labby
BACKUP_EMAIL_RECIPIENTS=

# Google Drive backup target
GOOGLE_DRIVE_FOLDER_ID=

# OneDrive backup target
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REFRESH_TOKEN=
ONEDRIVE_TENANT_ID=common
ONEDRIVE_FOLDER=/Apps/Labby
