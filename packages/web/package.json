{
  "name": "@labby/web",
  "version": "0.1.0",
  "description": "Labby web UI – Preact + Vite + vanilla-extract",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "VITE_DB_CONFIG=idb VITE_DEPLOYMENT_MODE=frontend-only vite",
    "dev:server": "VITE_DB_CONFIG=api VITE_DEPLOYMENT_MODE=server vite",
    "build": "pnpm --filter @labby/core rust:build:wasm:web && tsc -p tsconfig.json --noEmit && vite build",
    "build:frontend": "VITE_DB_CONFIG=idb VITE_DEPLOYMENT_MODE=frontend-only tsc -p tsconfig.json --noEmit && vite build",
    "build:server": "VITE_DB_CONFIG=api VITE_DEPLOYMENT_MODE=server tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "i18n:gen": "tsx scripts/i18n-gen.ts"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@labby/core": "workspace:*",
    "@msgpack/msgpack": "^3.1.3",
    "@preact/signals": "^2.9.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "idb": "^8.0.3",
    "lucide-preact": "^1.7.0",
    "nanoid": "^5.1.7",
    "papaparse": "^5.5.3",
    "preact": "^10.29.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/d3": "^7.4.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "js-yaml": "^4.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
