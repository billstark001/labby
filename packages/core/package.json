{
  "name": "@labby/core",
  "version": "0.1.0",
  "description": "Core algorithms, data structures and type definitions for Labby",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm rust:build && tsc -p tsconfig.json",
    "rust:build": "node ./scripts/build-rust.mjs all",
    "rust:build:node": "node ./scripts/build-rust.mjs node",
    "rust:build:wasm:web": "node ./scripts/build-rust.mjs wasm-web",
    "rust:build:wasm:node": "node ./scripts/build-rust.mjs wasm-node",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "triplet:cli": "pnpm exec tsx scripts/triplet-supervision-cli.ts",
    "test:js": "vitest run",
    "test:rust": "cd native && cargo test --workspace",
    "test": "pnpm test:rust && pnpm test:js"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "marked": "^17.0.6"
  }
}
